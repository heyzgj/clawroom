#!/usr/bin/env node
// skill/cli/clawroom — v4 Direct Mode bash entrypoint over skill/lib/*.
//
// Subcommands (each = single deterministic action, no LLM):
//   create        --topic --goal [--opening "..."] [--create-key] [--relay] [--debug]
//   resolve       --invite
//   join          --invite [--relay] [--debug]
//   post          --room --role --text [--logical-post-id] [--allow-pending-owner-ask]
//   poll          --room --role [--after N] [--wait S] [--no-state]
//   watch         --room --role [--include-self] [--once]
//   heartbeat     --room --role [--wait S] [--lease-ttl S] [--exit-code-mode]
//                 DUMB wakeup CHECK: detect room state, say whether to wake the
//                 primary agent. NEVER reads bodies / advances cursor / posts.
//   arm           --room --role [--runtime claude|codex] [--agent-cwd DIR]
//                 [--interval 60] [--lease-ttl 600]
//                 Self-verifying: register a macOS launchd job that runs the
//                 heartbeat tick on a timer so the room self-drives. (macOS only.)
//   disarm        --room --role   Boot out the launchd job + rm the per-room base.
//   close         --room --role --draft-file PATH
//   resume        --room --role [--debug]
//   lint          --room --role (--text TEXT | --before-close --draft-file PATH)
//   ask-owner     --room --role --question-id --question-text [--timeout-seconds] [--context-json]
//   owner-reply   --room --role --question-id --decision approve|reject --evidence [--source]
//   readiness     [--relay] [--thread-id --role] [--allow-tentative]
//   probe-limits  [--relay] [--create-key]
//
// Tokens are read from the local state file written by create/join.

import fs from 'node:fs';
import os from 'node:os';
import path from 'node:path';
import { spawnSync } from 'node:child_process';
import { fileURLToPath } from 'node:url';
import {
  RelayClient,
  RelayError,
  createRoom,
  joinRoom,
  resolveInvite,
} from '../lib/relay-client.mjs';
import {
  initState,
  readState,
  writeState,
  resumeRoom,
  setCursor,
  setWakeLease,
  setPendingOwnerAsk,
  resolveOwnerAsk,
  clearOwnerAnsweredWake,
  pendingAskTimedOut,
  stateFingerprint,
} from '../lib/state.mjs';
import { validateAndPrepareClose, validateCloseDraft, validateCloseAgainstState } from '../lib/close.mjs';
import { lintBeforeSend, lintBeforeClose } from '../lib/lint/index.mjs';
import { watchEvents } from '../lib/watch.mjs';
import {
  DEFAULT_RELAY_URL,
  MAX_MESSAGE_TEXT_CHARS,
  MAX_CLOSE_SUMMARY_CHARS,
  DEFAULT_MAX_THREAD_MS,
  DEFAULT_WAKE_LEASE_TTL_SECONDS,
  STATE_DIR,
  makeWatchEvent,
  ownerAskTimeoutSentinel,
  ownerAnsweredSentinel,
} from '../lib/types.mjs';

const VERSION = '0.6.1';

const argv = process.argv.slice(2);
const command = argv[0];
const flags = parseFlags(argv.slice(1));

main().catch((err) => {
  if (err instanceof RelayError && err.status === 409) {
    // not_your_turn is a NORMAL race, not a failure: the peer posted
    // while you were composing. Correct move: poll to read what they
    // said, then recompose. Exit 7 so agents distinguish this from
    // fatal (2) and never report it to the owner as an error.
    process.stderr.write(
      `peer_turn 409 ${err.message}\n` +
      `The peer posted while you were composing. This is normal. ` +
      `Run: clawroom poll --room <room> --role <role> to read their message, then post again.\n`
    );
    process.exit(7);
  }
  if (err instanceof RelayError && err.fatal) {
    process.stderr.write(`fatal ${err.status} ${err.message}\n`);
    process.exit(2);
  }
  process.stderr.write(`${err?.message || err}\n`);
  process.exit(1);
});

async function main() {
  switch (command) {
    case 'create':       return cmdCreate();
    case 'resolve':      return cmdResolve();
    case 'join':         return cmdJoin();
    case 'post':         return cmdPost();
    case 'poll':         return cmdPoll();
    case 'watch':        return cmdWatch();
    case 'heartbeat':    return cmdHeartbeat();
    case 'arm':          return cmdArm();
    case 'disarm':       return cmdDisarm();
    case 'close':        return cmdClose();
    case 'resume':       return cmdResume();
    case 'lint':         return cmdLint();
    case 'ask-owner':    return cmdAskOwner();
    case 'owner-reply':  return cmdOwnerReply();
    case 'readiness':    return cmdReadiness();
    case 'probe-limits': return cmdProbeLimits();
    case 'version':      return printJson({ version: VERSION });
    case 'help':
    case undefined:
      return printHelp();
    default:
      process.stderr.write(`unknown command: ${command}\nrun: clawroom help\n`);
      process.exit(2);
  }
}

// ---------- subcommands ----------

async function cmdCreate() {
  const topic = required('topic');
  const goal = flags.goal || '';
  const relay = relayUrl();
  const create_key = flags['create-key'] || process.env.CLAWROOM_CREATE_KEY;
  // Phase 5 case 3 finding ② — cold subagents created rooms but skipped
  // the opening-post step and falsely reported success. `--opening` makes
  // create+post atomic so the agent cannot split them by accident.
  const opening = flags.opening;
  const result = await createRoom({ topic, goal, relay, create_key });
  const room_id = result.thread_id;
  const host_token = result.host_token;
  // Codex P1.B + invariant 17: host state stores ONLY host_token. The guest
  // token from the relay response lives in the invite URL only; we hand it
  // off and forget it. Persisting it here would let the host accidentally
  // post as guest, which invariant 17 forbids.
  initState({
    room_id,
    role: 'host',
    host_token,
    topic,
    goal,
    relay,
  });
  // Atomic opening post (Phase 5 case 3 fix). If --opening present, post
  // immediately before reporting create as done. State must reflect the
  // posted id; final output names both the invite + the opening id so
  // owner-facing summaries can't claim the room is "live" without one.
  let opening_id = null;
  if (typeof opening === 'string' && opening.length > 0) {
    if (opening.length > MAX_MESSAGE_TEXT_CHARS) {
      throw new Error(`create: --opening text exceeds MAX_MESSAGE_TEXT_CHARS=${MAX_MESSAGE_TEXT_CHARS}`);
    }
    const state = mustReadState(room_id, 'host');
    const token = mustToken(state);
    const client = new RelayClient({ relay, room_id, role: 'host', token });
    const postResult = await client.postMessage({
      text: opening,
      previous_cursor_or_parent_id: state.last_event_cursor,
      logical_post_id: 'opening',
    });
    const postedId = Number(/** @type {any} */ (postResult.body)?.id);
    if (Number.isFinite(postedId) && postedId > state.last_event_cursor) {
      setCursor(state, postedId);
    }
    opening_id = Number.isFinite(postedId) ? postedId : null;
  }
  // Output redacted by default (Codex P2.2). state_file path can leak via
  // owner-facing surfaces, so behind --debug.
  const debug = Boolean(flags.debug);
  const out = {
    ok: true,
    role: 'host',
    room_id,
    invite_url: result.public_invite_url,
    public_message: result.public_message,
  };
  if (opening_id !== null) out.opening_id = opening_id;
  if (debug) out.state_file = `${STATE_DIR}/${room_id}-host.state.json`;
  printJson(out);
}

async function cmdResolve() {
  const invite = required('invite');
  printJson(resolveInvite(invite));
}

async function cmdJoin() {
  const invite = required('invite');
  const parsed = resolveInvite(invite);
  // Codex P1: public invites must carry their relay origin so BYO / hosted
  // fallback joins go to the right relay. Precedence: explicit --relay flag
  // (caller override) > invite origin > DEFAULT_RELAY_URL.
  const relay = flags.relay || parsed.relay || DEFAULT_RELAY_URL;
  const joined = await joinRoom({ relay, thread_id: parsed.thread_id, invite_code: parsed.invite_code });
  const room_id = parsed.thread_id;
  const guest_token = joined.token || joined.guest_token;
  if (!guest_token) throw new Error('join: relay did not return a guest token');
  initState({
    room_id,
    role: 'guest',
    guest_token,
    topic: joined.topic,
    goal: joined.goal,
    relay,
  });
  // Output redacted by default (Codex P2.2): callers may relay output to
  // owners verbatim. --debug shows state_file path. topic/goal included so
  // a cold guest agent learns what the room is about from the join output
  // itself instead of needing a second resume/state read.
  const debug = Boolean(flags.debug);
  const out = { ok: true, role: 'guest', room_id, relay, topic: joined.topic || '', goal: joined.goal || '' };
  if (debug) out.state_file = `${STATE_DIR}/${room_id}-guest.state.json`;
  printJson(out);
}

async function cmdPost() {
  const room_id = required('room');
  const role = requiredRole();
  const text = required('text');
  if (text.length > MAX_MESSAGE_TEXT_CHARS) {
    throw new Error(`post: text exceeds MAX_MESSAGE_TEXT_CHARS=${MAX_MESSAGE_TEXT_CHARS}`);
  }
  const state = mustReadState(room_id, role);
  // Codex pass 4 P1: pending_owner_ask MUST hard-block posting past the
  // mandate boundary (invariant 13). A warning on stderr is too soft; the
  // primary agent can ignore it. Fail closed unless caller explicitly opts
  // out with --allow-pending-owner-ask (only for known-safe status updates
  // that don't touch the mandate).
  if (state.pending_owner_ask && !flags['allow-pending-owner-ask']) {
    process.stderr.write(
      `post: blocked — pending_owner_ask "${state.pending_owner_ask.question_id}" is unresolved. ` +
      `Resolve via clawroom owner-reply, or pass --allow-pending-owner-ask for a status-only message ` +
      `that does NOT touch the mandate boundary.\n`
    );
    process.exit(5);
  }
  // Pre-send lint runs but does not block; surface findings to stderr.
  const lint = lintBeforeSend({ text, state });
  for (const f of lint.findings) {
    if (f.severity === 'error') {
      process.stderr.write(`lint error ${f.code}: ${f.message}\n`);
      process.exit(2);
    }
    process.stderr.write(`lint ${f.severity} ${f.code}: ${f.message}\n`);
  }
  const token = mustToken(state);
  const client = new RelayClient({ relay: relayUrl(state), room_id, role, token });
  const result = await client.postMessage({
    text,
    previous_cursor_or_parent_id: state.last_event_cursor,
    logical_post_id: flags['logical-post-id'],
  });
  // Codex pass 3 P2: advance cursor to our own posted id so future posts
  // see the right parent and resume sees the right starting point.
  const postedId = Number(/** @type {any} */ (result.body)?.id);
  if (Number.isFinite(postedId) && postedId > state.last_event_cursor) {
    setCursor(state, postedId);
  }
  // Consume the owner-answered wake signal: the agent woke on owner_answered and
  // has now posted its reply, so the signal is spent — clear it (merge-write,
  // so a concurrent heartbeat lease survives) to stop the heartbeat re-waking.
  if (state.owner_answered_wake) {
    clearOwnerAnsweredWake(state);
  }
  printJson({ ok: true, id: postedId, attempts: result.attempts });
}

async function cmdPoll() {
  const room_id = required('room');
  const role = requiredRole();
  const wait = Number(flags.wait ?? '0');
  const state = mustReadState(room_id, role);
  const token = mustToken(state);
  // Default --after = state.last_event_cursor so callers don't have to
  // track cursor manually. Explicit --after overrides.
  const after = flags.after !== undefined ? Number(flags.after) : state.last_event_cursor;
  const client = new RelayClient({ relay: relayUrl(state), room_id, role, token });
  const result = await client.pollMessages({ after, waitSeconds: wait });
  // Codex P2.1: persist cursor so idempotency keys / resume see the right
  // parent_id. Use --no-state to opt out (e.g. read-only inspection).
  const rows = Array.isArray(result.body) ? result.body : [];
  if (rows.length && !flags['no-state']) {
    const maxId = rows.reduce((m, r) => (typeof r?.id === 'number' && r.id > m ? r.id : m), state.last_event_cursor);
    if (maxId > state.last_event_cursor) setCursor(state, maxId);
  }
  printJson(result.body);
}

async function cmdWatch() {
  const room_id = required('room');
  const role = requiredRole();
  const include_self = Boolean(flags['include-self']);
  // --once: Pattern B' driver. Exit after the first peer event (any kind).
  // Lets cross-runtime callers like Codex re-invoke watch per turn instead
  // of forking a long-running background process.
  const once = Boolean(flags.once);
  const state = mustReadState(room_id, role);
  const token = mustToken(state);
  // watchEvents emits its own lines to stdout; this returns when room mutually closes,
  // or when --once and the first peer event has been emitted.
  const result = await watchEvents({
    relay: relayUrl(state),
    room_id,
    role,
    token,
    include_self,
    once,
  });
  process.stderr.write(JSON.stringify(result) + '\n');
  const okReasons = new Set(['mutual_close', 'ok', 'once_event_emitted']);
  if (!okReasons.has(result.exit_reason)) {
    process.exit(1);
  }
}

// Phase 6.5 P0 — a DUMB wakeup CHECK. It detects room state and says whether
// to wake the primary agent. It NEVER reads message bodies, NEVER advances the
// read cursor, NEVER replies, NEVER makes a business decision. It knocks on the
// door; it never speaks. (NOT a bridge, NOT a brain.)
//
// Output: COMPACT single-line JSON (no indentation) so a line-based scheduler
// parser reads exactly one line per tick (wakeup-recipes.md). printJson stays
// pretty for other commands; heartbeat prints its own compact form.
//   {"ok":true,"action":...,"reason":...,"room":...,"role":...,"event_id":N}
//   action ∈ {wake_agent, noop, notify_owner, cancel}
//   reason ∈ {peer_event, peer_close, no_new_event, self_event, wake_inflight,
//             pending_owner_ask, owner_ask_timeout, owner_answered,
//             mutual_close, ttl}
//
// FAIL CLOSED on a body-leaking relay (invariant 9): every raw /events item is
// run through makeWatchEvent (which throws on any disallowed field like `text`);
// if it throws, heartbeat emits ok:false and exits non-zero EVEN in default mode,
// because a relay leaking message bodies is a real error, not a detection.
//
// Exit codes:
//   default        — 0 on ANY successful detection (the JSON carries action);
//                    non-zero ONLY on real errors (bad args, unreadable state,
//                    invariant-9 leak, network failure after the client's normal
//                    retries). A noop is NOT a failure.
//   --exit-code-mode (opt-in) — 0 wake_agent / 3 noop / 4 cancel / 5 notify_owner.
async function cmdHeartbeat() {
  const room_id = required('room');
  const role = requiredRole();
  const exitCodeMode = Boolean(flags['exit-code-mode']);
  // Bounded tick, NOT a long-poll. Default wait=0; allow a couple seconds.
  const wait = flags.wait !== undefined ? Number(flags.wait) : 0;
  if (!Number.isFinite(wait) || wait < 0) {
    throw new Error(`heartbeat: --wait must be a non-negative number, got "${flags.wait}"`);
  }
  const leaseTtlRaw = flags['lease-ttl'] ?? DEFAULT_WAKE_LEASE_TTL_SECONDS;
  const leaseTtlSeconds = Number(leaseTtlRaw);
  if (!Number.isFinite(leaseTtlSeconds) || leaseTtlSeconds <= 0) {
    throw new Error(`heartbeat: --lease-ttl must be a positive number, got "${leaseTtlRaw}"`);
  }

  // (a) Read local state. mustReadState throws (exit 1) if unreadable/missing.
  const state = mustReadState(room_id, role);
  const cursor = state.last_event_cursor;
  const lastWakeId = typeof state.last_wakeup_event_id === 'number' ? state.last_wakeup_event_id : 0;
  const inflightUntil = state.wakeup_inflight_until ? Date.parse(state.wakeup_inflight_until) : 0;
  const now = Date.now();

  const decide = (action, reason, eventId = null) => ({
    ok: true,
    action,
    reason,
    room: room_id,
    role,
    event_id: eventId,
  });

  // Compact single-line print (Finding 4): a scheduler parses one line per tick.
  // We do NOT use the shared printJson (pretty, multi-line) — other commands may
  // rely on its indentation; heartbeat owns this compact form.
  const printCompact = (obj) => process.stdout.write(JSON.stringify(obj) + '\n');

  const emit = (decision) => {
    printCompact(decision);
    if (exitCodeMode) {
      const code = { wake_agent: 0, noop: 3, cancel: 4, notify_owner: 5 }[decision.action];
      process.exit(code === undefined ? 1 : code);
    }
    // Default mode: any successful detection is exit 0 (the JSON carries action).
    process.exit(0);
  };

  // Hard error (NOT a detection): a body-leaking relay (invariant 9) or other
  // real failure. Emits ok:false and exits non-zero in BOTH modes — heartbeat
  // must FAIL CLOSED rather than silently proceed past a leak.
  const emitError = (reason, detail) => {
    printCompact({ ok: false, action: 'error', reason, room: room_id, role, event_id: null });
    if (detail) process.stderr.write(`heartbeat: ${detail}\n`);
    process.exit(2);
  };

  // (b) Blocked on the OWNER. Two sub-cases:
  if (state.pending_owner_ask) {
    if (!pendingAskTimedOut(state)) {
      // Still within the owner's window → notify_owner, do NOT poll. Waking the
      // agent is useless while it waits on a human decision.
      emit(decide('notify_owner', 'pending_owner_ask'));
      return;
    }
    // (b2) Finding 2: the ask TIMED OUT but is still set, so `post` and an
    // agreement close stay blocked — the room would silently stall. Wake the
    // agent so it can run the no_agreement/partial timeout closure. Still dumb:
    // no semantics, just "wake, the ask timed out."
    //
    // Dedupe so we don't re-wake every tick. We reuse the wake-lease fields but
    // key this case on a STABLE RESERVED SENTINEL id derived from the pending
    // ask's question_id: a negative number. Real /events ids are >= 0
    // (makeWatchEvent rejects id < 0; the cursor floor is -1), so a negative
    // sentinel can never collide with a real peer event id. We match the lease
    // EXACTLY (=== sentinel), not with the monotonic `<=` used for real events,
    // because the sentinel is not part of the event sequence.
    const sentinel = ownerAskTimeoutSentinel(state.pending_owner_ask.question_id);
    if (lastWakeId === sentinel && now < inflightUntil) {
      emit(decide('noop', 'wake_inflight', sentinel));
      return;
    }
    const until = new Date(now + leaseTtlSeconds * 1000).toISOString();
    setWakeLease(state, sentinel, until);
    emit(decide('wake_agent', 'owner_ask_timeout', sentinel));
    return;
  }

  // (b3) The OWNER ANSWERED (approve OR reject) out-of-band via owner-reply,
  // which cleared pending_owner_ask and set owner_answered_wake. pending is now
  // gone so we fall through (b) above. But the peer is just waiting for our
  // reply — there is NO new peer event — so the relay-poll branch (c) below
  // would noop forever, leaving the owner's answer recorded-but-unacted and the
  // room silently stalled. Wake the agent to ACT on the answer. Still DUMB: we
  // read only the state flag's question_id (no message body, no decision
  // semantics here — the agent reads the recorded approval itself). Dedupe on a
  // STABLE RESERVED SENTINEL keyed off the question_id, matched EXACTLY against
  // the lease (=== sentinel), exactly like the owner_ask_timeout case. The
  // agent clears owner_answered_wake on its next successful post/close, so this
  // does not loop once acted on.
  if (state.owner_answered_wake) {
    const sentinel = ownerAnsweredSentinel(state.owner_answered_wake.question_id);
    if (lastWakeId === sentinel && now < inflightUntil) {
      emit(decide('noop', 'wake_inflight', sentinel));
      return;
    }
    const until = new Date(now + leaseTtlSeconds * 1000).toISOString();
    setWakeLease(state, sentinel, until);
    emit(decide('wake_agent', 'owner_answered', sentinel));
    return;
  }

  // (c) Poll the relay events endpoint as THIS role — metadata only (id, from,
  // kind), a short bounded tick. NEVER /messages, NEVER message bodies.
  const token = mustToken(state);
  const client = new RelayClient({ relay: relayUrl(state), room_id, role, token });

  // Local TTL prediction (backstop): the relay is the authority and answers
  // 410 thread_expired when a room is past its max age, but if the relay is
  // unreachable we still want to recognize a room that is *certainly* dead
  // (started_at + TTL < now) rather than report a network failure for a room
  // that can no longer make progress.
  const startedAtMs = state.started_at ? Date.parse(state.started_at) : NaN;
  const locallyExpired = Number.isFinite(startedAtMs) && now > startedAtMs + DEFAULT_MAX_THREAD_MS;

  let events;
  try {
    const result = await client.pollEvents({ after: cursor, waitSeconds: wait });
    events = Array.isArray(result.body) ? result.body : [];
  } catch (err) {
    // (e) Relay says the room expired (410). cancel/ttl — not an error.
    if (err instanceof RelayError && err.status === 410) {
      emit(decide('cancel', 'ttl'));
      return;
    }
    // Network failure after the client's normal retries: if the room is past
    // its local TTL it cannot progress anyway → cancel/ttl; otherwise this is
    // a real error (non-zero exit, surfaced to the caller / scheduler).
    if (locallyExpired) {
      emit(decide('cancel', 'ttl'));
      return;
    }
    throw err;
  }

  const peerRole = role === 'host' ? 'guest' : 'host';

  // (d/e/f) Scan the polled events (metadata only). Find the highest new id,
  // the highest-id PEER event, and whether any close event appeared this tick.
  //
  // Finding 1 / invariant 9: run EVERY raw event through makeWatchEvent before
  // inspecting it — exactly as watch.mjs does. It throws if the relay leaked a
  // body/`text` field (or any non-allowed field) and trims to {id, from, kind,
  // ts}. If it throws, FAIL CLOSED: a body-leaking relay is a real error, so we
  // emit ok:false and exit non-zero rather than silently proceeding.
  let maxId = cursor;
  let peerEvent = null;     // highest-id peer event strictly newer than the cursor
  let closeEventSeen = false;
  for (const raw of events) {
    let ev;
    try {
      ev = makeWatchEvent(raw);
    } catch (err) {
      emitError('invariant9_violation', `relay leaked a disallowed field on a /events item — ${err?.message || err}`);
      return;
    }
    const id = ev.id;
    if (id <= cursor) continue;
    if (id > maxId) maxId = id;
    if (ev.kind === 'close') closeEventSeen = true;
    if (ev.from === peerRole) {
      if (!peerEvent || id > Number(peerEvent.id)) peerEvent = ev;
    }
  }

  // (d) Authoritative close check via /join close_state — ONLY when a close
  // event surfaced this tick. close_state is the authority for mutual vs
  // peer-only (a peer close event alone can't tell us if WE already closed).
  // This is METADATA ONLY: we read the boolean host_closed/guest_closed/closed
  // flags and NEVER the summary or last_message body the snapshot carries.
  // Mirrors watch.mjs using /join as the close authority. Skipping it on the
  // common no-close tick keeps heartbeat a single GET.
  let weClosed = false;
  if (closeEventSeen) {
    let closeState = null;
    try {
      const join = await client.join();
      closeState = /** @type {any} */ (join.body)?.close_state || null;
    } catch (err) {
      if (err instanceof RelayError && err.status === 410) { emit(decide('cancel', 'ttl')); return; }
      if (locallyExpired) { emit(decide('cancel', 'ttl')); return; }
      throw err;
    }
    if (Boolean(closeState?.closed)) {
      emit(decide('cancel', 'mutual_close'));
      return;
    }
    weClosed = Boolean(role === 'host' ? closeState?.host_closed : closeState?.guest_closed);
  }

  // (e) Local TTL backstop: relay 410 (caught around the polls) is the primary
  // expiry signal; this catches a room past its client-side max age when the
  // relay didn't 410 (e.g. relay max-age lowered after this room started).
  if (locallyExpired) {
    emit(decide('cancel', 'ttl'));
    return;
  }

  // (f) New events past the cursor?
  if (maxId <= cursor) {
    // No event newer than the cursor at all.
    emit(decide('noop', 'no_new_event'));
    return;
  }
  if (!peerEvent) {
    // Newer events exist but they are ALL from us (echoes of our own posts).
    emit(decide('noop', 'self_event'));
    return;
  }

  // A peer event exists. DEDUPE against the wake-lease: if this event id is not
  // newer than the one we last woke for AND the lease is still in-flight, the
  // agent is already handling it — do not wake again.
  const peerId = Number(peerEvent.id);
  if (peerId <= lastWakeId && now < inflightUntil) {
    emit(decide('noop', 'wake_inflight', peerId));
    return;
  }

  // Wake. peer CLOSE (peer closed, we haven't) is its own reason so the agent
  // knows to move toward an echo-close rather than another message turn.
  const isPeerClose = String(peerEvent.kind) === 'close' && !weClosed;
  const reason = isPeerClose ? 'peer_close' : 'peer_event';

  // Write the lease (ONLY the two lease fields, via the re-read-merge guard so
  // a concurrent agent turn's pending_owner_ask / approvals / cursor survive).
  const until = new Date(now + leaseTtlSeconds * 1000).toISOString();
  setWakeLease(state, peerId, until);

  emit(decide('wake_agent', reason, peerId));
}

// ---------- arm / disarm (macOS launchd unattended monitoring) ----------
//
// `arm` encapsulates the validated launchd recipe (references/wakeup-recipes.md
// Recipe B) as ONE command the AGENT runs right after create/join, so the room
// self-drives and the owner never becomes the relay. It writes per-room files,
// registers a launchd job pointing at the canonical bundled tick
// (lib/wakeup-tick.sh), and SELF-VERIFIES (job loaded + one clean heartbeat)
// before reporting success — leaving NO half-armed/broken job behind.
//
// macOS launchd ONLY for now (Linux systemd --user is a TODO). The agent tells
// the owner a plain sentence ("I'm now watching this room"); this JSON is for
// the agent and is never shown to the owner — it carries no tokens/paths in any
// owner-facing surface, only the label/log path the agent uses to disarm/debug.

function armPlatformGuard() {
  if (process.platform !== 'darwin') {
    throw new Error(
      'arm: macOS launchd only for now (this is darwin-specific). ' +
      'Linux systemd --user support is a TODO. ' +
      'Fall back to asking the owner to nudge, or run the heartbeat manually.'
    );
  }
}

/**
 * The directory containing THIS CLI's skill (the dir that holds SKILL.md). The
 * CLI lives at <skillDir>/cli/clawroom, so the skill dir is two levels up. The
 * launchd tick must `cd` here, so it must be the INSTALLED skill, not a dev
 * checkout under a TCC-protected dir.
 */
function skillDir() {
  const __dirname = path.dirname(fileURLToPath(import.meta.url));
  return path.resolve(__dirname, '..');
}

/** Read the version: field from a SKILL.md frontmatter. Null if unreadable. */
function readSkillVersion(skillMdPath) {
  try {
    const m = fs.readFileSync(skillMdPath, 'utf8').match(/version:\s*["']?([0-9][0-9.]*)/);
    return m ? m[1] : null;
  } catch { return null; }
}

/**
 * The skill dir the launchd job + woken agent actually run from. A launchd
 * background job CANNOT cwd into ~/Desktop, ~/Documents, or ~/Downloads (macOS
 * denies it, EPERM uv_cwd) — but real projects live under exactly those. So
 * rather than REFUSE to arm there (which silently degraded the user to a
 * session-bound, dies-on-close fallback), we RELOCATE a copy of the skill to a
 * stable non-Desktop runtime dir (~/.clawroom/skill-runtime) and launchd from
 * THERE. The original install stays put. The cold-pickup wake needs no project
 * context — it reconstructs everything from state + relay history — so running
 * from the copy is safe and equally durable. When the skill is already outside
 * TCC dirs it's used in place. Throws only if the relocate can't be written.
 */
function resolveRuntimeSkillDir(dir) {
  const home = os.homedir();
  const tccDirs = ['Desktop', 'Documents', 'Downloads'].map((d) => path.join(home, d));
  const resolved = path.resolve(dir);
  const underTcc = tccDirs.some((tcc) => resolved === tcc || resolved.startsWith(tcc + path.sep));
  if (!underTcc) return resolved;
  const runtime = path.join(home, '.clawroom', 'skill-runtime');
  // Refresh only when missing or version-stale — never re-copy under a live tick
  // for no reason. Copy just the executable + doc surface.
  const srcVer = readSkillVersion(path.join(resolved, 'SKILL.md'));
  const dstVer = readSkillVersion(path.join(runtime, 'SKILL.md'));
  const stale = !fs.existsSync(path.join(runtime, 'cli', 'clawroom')) || !srcVer || dstVer !== srcVer;
  if (stale) {
    try {
      fs.rmSync(runtime, { recursive: true, force: true });
      fs.mkdirSync(runtime, { recursive: true });
      for (const item of ['cli', 'lib', 'references', 'SKILL.md']) {
        const s = path.join(resolved, item);
        if (fs.existsSync(s)) fs.cpSync(s, path.join(runtime, item), { recursive: true });
      }
    } catch (e) {
      throw new Error(`arm: could not relocate the skill out of a TCC dir to ${runtime}: ${e.message}`);
    }
  }
  return runtime;
}

/** Per-room base dir: $HOME/.clawroom/<room>-<role>/ (separate from STATE_DIR). */
function armBaseDir(room_id, role) {
  return path.join(os.homedir(), '.clawroom', `${room_id}-${role}`);
}

function armLabel(room_id, role) {
  // Launchd label prefix is inlined (not a module-level const) so it is never
  // in the temporal dead zone when main() runs synchronously at module load.
  return `cc.clawroom.wake.${room_id}-${role}`;
}

function plistPath(label) {
  return path.join(os.homedir(), 'Library', 'LaunchAgents', `${label}.plist`);
}

/** XML-escape a string for safe embedding in plist <string> values. */
function xmlEscape(s) {
  return String(s)
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&apos;');
}

/** Is a launchd label currently loaded for this gui domain? */
function launchdLabelLoaded(label) {
  // `launchctl list <label>` exits 0 and prints a dict if loaded; non-zero if not.
  const r = spawnSync('launchctl', ['list', label], { encoding: 'utf8' });
  return r.status === 0;
}

/** Boot out a launchd label from the current gui domain (idempotent). */
function launchdBootout(label) {
  const uid = process.getuid ? process.getuid() : 0;
  spawnSync('launchctl', ['bootout', `gui/${uid}/${label}`], { encoding: 'utf8' });
}

/**
 * The default per-room wake prompt (wakeup-recipes.md step 2 wording). A
 * function, not a module-level const, so it is never in the temporal dead zone
 * when main() runs synchronously at module load (the bug that bit arm/disarm).
 */
function wakePromptText(room_id, role) {
  return (
    "You are the " + role + " agent for an ongoing ClawRoom room (room id: " + room_id + "). " +
    "Your monitor woke you because the peer moved or the room needs attention. You are " +
    "starting FRESH this turn with no memory of earlier turns, so reconstruct context first " +
    "(your cwd is the ClawRoom skill directory):\n" +
    "1. Load the room state:\n" +
    "     ./cli/clawroom resume --room " + room_id + " --role " + role + "\n" +
    "2. Read the FULL conversation so far AND your owner's recorded constraints:\n" +
    "     ./cli/clawroom poll --room " + room_id + " --role " + role + " --after -1 --no-state\n" +
    "3. Then act per SKILL.md: if the peer is owed a reply, compose and POST it, then END this " +
    "turn — do NOT keep polling or waiting in-loop for the peer's reply; your monitor wakes you " +
    "again when they move (staying in-loop just burns time). If you need the owner's decision, " +
    "run ./cli/clawroom ask-owner to RECORD it in state FIRST — never ask in bare turn-text and " +
    "stop (an unattended scheduler can't see a bare question, so the room stalls).\n" +
    "4. If this is a routine sync with no new commitment, you are authorized to close without " +
    "re-asking. Close only when both sides' goals are genuinely met — not prematurely.\n"
  );
}

/**
 * The per-room wake-agent.sh body. Reads the prompt from a FILE (no eval, no
 * inline quoting — an apostrophe/paren in the prompt can never break the
 * invocation). <resume> differs per runtime; the tick only needs this to wake
 * one turn.
 */
function wakeAgentScript(runtime) {
  // Cold pickup, NOT session resume: a session is keyed to the cwd where the
  // agent was originally launched, which an unattended scheduler cannot know
  // or reach. So wake a FRESH agent and let it reconstruct context from room
  // state + relay history (the wake prompt carries the room id + role and tells
  // it to resume+poll). This is cwd/TCC-robust and matches the externalized-
  // state design — `claude --continue` in an arm-made work dir resumed nothing.
  const invoke =
    runtime === 'codex'
      ? 'exec codex exec "$(cat "${CLAWROOM_WAKE_PROMPT_FILE:?}")"'
      : 'exec claude -p "$(cat "${CLAWROOM_WAKE_PROMPT_FILE:?}")" \\\n' +
        '  --model sonnet --permission-mode acceptEdits --allowedTools "Bash,Read,Write,Glob,Grep"';
  return (
    '#!/usr/bin/env bash\n' +
    '# Per-room agent-wake script written by `clawroom arm`. Wakes a FRESH agent\n' +
    '# for ONE cold-pickup turn (context from room state + history, not session\n' +
    '# resume) and reads the prompt from a file (no eval, no inline quoting).\n' +
    'set -euo pipefail\n' +
    'cd "${CLAWROOM_AGENT_CWD:?}"\n' +
    invoke + '\n'
  );
}

/**
 * Build the launchd plist XML. ProgramArguments points at the CANONICAL bundled
 * tick (lib/wakeup-tick.sh), never a per-room copy. All per-room variation is in
 * EnvironmentVariables. PATH includes the node dir so launchd's bare
 * PATH=/usr/bin:/bin (which has no nvm node) doesn't silently kill every tick.
 */
function buildPlist({ label, tickScript, nodeDir, room_id, role, skill_dir, stateDir, wakeLog, agentScript, agentCwd, promptFile, interval }) {
  const env = {
    PATH: `${nodeDir}:/usr/bin:/bin`,
    CLAWROOM_ROOM: room_id,
    CLAWROOM_ROLE: role,
    CLAWROOM_SKILL_DIR: skill_dir,
    CLAWROOM_STATE_DIR: stateDir,
    CLAWROOM_WAKE_LOG: wakeLog,
    CLAWROOM_LAUNCHD_LABEL: label,
    CLAWROOM_AGENT_SCRIPT: agentScript,
    CLAWROOM_AGENT_CWD: agentCwd,
    CLAWROOM_WAKE_PROMPT_FILE: promptFile,
  };
  const envXml = Object.entries(env)
    .map(([k, v]) => `    <key>${xmlEscape(k)}</key><string>${xmlEscape(v)}</string>`)
    .join('\n');
  return (
    '<?xml version="1.0" encoding="UTF-8"?>\n' +
    '<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">\n' +
    '<plist version="1.0"><dict>\n' +
    `  <key>Label</key><string>${xmlEscape(label)}</string>\n` +
    '  <key>ProgramArguments</key><array>\n' +
    `    <string>/bin/bash</string><string>${xmlEscape(tickScript)}</string>\n` +
    '  </array>\n' +
    '  <key>EnvironmentVariables</key><dict>\n' +
    envXml + '\n' +
    '  </dict>\n' +
    `  <key>StartInterval</key><integer>${interval}</integer>\n` +
    '  <key>RunAtLoad</key><true/>\n' +
    '</dict></plist>\n'
  );
}

async function cmdArm() {
  armPlatformGuard();
  const room_id = required('room');
  const role = requiredRole();
  const runtime = String(flags.runtime || 'claude');
  if (runtime !== 'claude' && runtime !== 'codex') {
    throw new Error(`arm: --runtime must be claude or codex, got "${runtime}"`);
  }
  const interval = Number(flags.interval ?? 60);
  if (!Number.isFinite(interval) || interval <= 0 || !Number.isInteger(interval)) {
    throw new Error(`arm: --interval must be a positive integer (seconds), got "${flags.interval}"`);
  }
  const leaseTtl = Number(flags['lease-ttl'] ?? DEFAULT_WAKE_LEASE_TTL_SECONDS);
  if (!Number.isFinite(leaseTtl) || leaseTtl <= 0) {
    throw new Error(`arm: --lease-ttl must be a positive number, got "${flags['lease-ttl']}"`);
  }

  // (1) Require the room state to exist — arm runs AFTER create/join. Missing
  // state is a loud failure: there is nothing to monitor.
  mustReadState(room_id, role); // throws (exit 1) if missing

  // (2) Resolve paths.
  const SKILL_DIR = skillDir();
  // (3) Resolve the RUNTIME skill dir. A launchd job can't cwd into ~/Desktop
  // etc.; if the skill lives there we relocate a copy OUT and run from it —
  // never refuse (refusing silently degraded users to a session-bound fallback
  // that dies on close). After this, the wake is equally durable wherever the
  // skill was installed.
  const RUNTIME_SKILL_DIR = resolveRuntimeSkillDir(SKILL_DIR);

  const nodeDir = path.dirname(process.execPath);
  const stateDir = STATE_DIR; // inherits CLAWROOM_STATE_DIR or the ~/.clawroom-v4 default
  const base = armBaseDir(room_id, role);
  // Cold-pickup wake runs in the (runtime) skill dir so ./cli/clawroom and
  // SKILL.md resolve directly (a fresh agent reconstructs context from
  // state+history, not a session resume — so it does NOT need the launch cwd).
  const agentCwd = flags['agent-cwd'] ? String(flags['agent-cwd']) : RUNTIME_SKILL_DIR;
  const label = armLabel(room_id, role);
  const tickScript = path.join(RUNTIME_SKILL_DIR, 'lib', 'wakeup-tick.sh');
  if (!fs.existsSync(tickScript)) {
    throw new Error(`arm: bundled tick missing at ${tickScript} — broken install`);
  }
  const wakeLog = path.join(stateDir, `wakeup-${room_id}-${role}.log`);
  const promptFile = path.join(base, 'wake-prompt.txt');
  const agentScript = path.join(base, 'wake-agent.sh');
  const plist = plistPath(label);

  // (4) Write the per-room files.
  fs.mkdirSync(base, { recursive: true });
  fs.mkdirSync(agentCwd, { recursive: true });
  fs.mkdirSync(stateDir, { recursive: true });
  fs.mkdirSync(path.dirname(plist), { recursive: true });
  fs.writeFileSync(promptFile, wakePromptText(room_id, role), 'utf8');
  fs.writeFileSync(agentScript, wakeAgentScript(runtime), { mode: 0o755 });

  // (6) Write the launchd plist pointing at the CANONICAL bundled tick.
  const plistXml = buildPlist({
    label, tickScript, nodeDir, room_id, role,
    skill_dir: RUNTIME_SKILL_DIR, stateDir, wakeLog, agentScript, agentCwd, promptFile, interval,
  });
  fs.writeFileSync(plist, plistXml, 'utf8');

  // (7) Idempotent: if already loaded, boot out first, then bootstrap fresh.
  if (launchdLabelLoaded(label)) launchdBootout(label);

  // (8) Bootstrap.
  const uid = process.getuid ? process.getuid() : 0;
  const boot = spawnSync('launchctl', ['bootstrap', `gui/${uid}`, plist], { encoding: 'utf8' });
  if (boot.status !== 0) {
    // Clean up: never leave a plist behind for a job that didn't load.
    launchdBootout(label);
    try { fs.unlinkSync(plist); } catch {}
    throw new Error(
      `arm: launchctl bootstrap failed (status ${boot.status}): ${(boot.stderr || boot.stdout || '').trim().slice(0, 200)}`
    );
  }

  // (9) Self-verify. Either failure → boot out + FAIL LOUD (never a half-armed job).
  const failArm = (detail) => {
    launchdBootout(label);
    try { fs.unlinkSync(plist); } catch {}
    throw new Error(`arm: self-verify failed — ${detail}. Booted out the job; nothing left armed.`);
  };
  if (!launchdLabelLoaded(label)) {
    failArm('job did not appear in launchctl list after bootstrap');
  }
  // One real heartbeat tick must return valid JSON with a known action. We run
  // the SAME CLI (this file) via the resolved node, with the same env the tick
  // would see, so PATH/cwd problems surface here, not silently at 2am.
  const hb = spawnSync(process.execPath, [fileURLToPath(import.meta.url), 'heartbeat', '--room', room_id, '--role', role], {
    cwd: RUNTIME_SKILL_DIR,
    env: { ...process.env, CLAWROOM_STATE_DIR: stateDir },
    encoding: 'utf8',
  });
  let hbJson;
  try {
    hbJson = JSON.parse((hb.stdout || '').trim());
  } catch {
    failArm(`heartbeat tick did not return valid JSON (stderr: ${(hb.stderr || '').trim().slice(0, 160)})`);
  }
  const VALID_ACTIONS = new Set(['wake_agent', 'noop', 'notify_owner', 'cancel']);
  if (!hbJson || hbJson.ok !== true || !VALID_ACTIONS.has(hbJson.action)) {
    failArm(`heartbeat tick returned an error or unknown action: ${JSON.stringify(hbJson)}`);
  }

  // (10) Success JSON (for the AGENT, never shown to the owner). No tokens.
  printJson({
    ok: true,
    armed: true,
    label,
    interval,
    room: room_id,
    role,
    wake_log: wakeLog,
  });
}

async function cmdDisarm() {
  // disarm is not platform-guarded as hard as arm: booting out a label / rming
  // a dir is harmless on any platform, and we want disarm to always be runnable
  // to clean up. launchctl simply no-ops if absent.
  const room_id = required('room');
  const role = requiredRole();
  const label = armLabel(room_id, role);
  const base = armBaseDir(room_id, role);
  const plist = plistPath(label);

  // Boot out (idempotent — no error if not loaded). macOS only; on other
  // platforms spawnSync just fails to find launchctl, which we ignore.
  if (process.platform === 'darwin') launchdBootout(label);
  // Remove the plist + the per-room base. rm is idempotent (no error if gone).
  try { fs.unlinkSync(plist); } catch {}
  try { fs.rmSync(base, { recursive: true, force: true }); } catch {}

  printJson({ ok: true, disarmed: true, label, room: room_id, role });
}

async function cmdClose() {
  const room_id = required('room');
  const role = requiredRole();
  const draftPath = required('draft-file');
  const draftRaw = fs.readFileSync(draftPath, 'utf8');
  let draft;
  try { draft = JSON.parse(draftRaw); } catch { throw new Error(`close: ${draftPath} is not valid JSON`); }
  const state = mustReadState(room_id, role);
  const prepared = validateAndPrepareClose({ draft, state });
  if (!prepared.ok) {
    process.stderr.write(`close: rejected, ${prepared.issues.length} issue(s):\n`);
    for (const it of prepared.issues) {
      process.stderr.write(`  ${it.code}${it.path ? ` @ ${it.path}` : ''}: ${it.message}\n`);
    }
    process.exit(3);
  }
  if (prepared.summary.length > MAX_CLOSE_SUMMARY_CHARS) {
    throw new Error(`close: canonical summary exceeds MAX_CLOSE_SUMMARY_CHARS=${MAX_CLOSE_SUMMARY_CHARS}`);
  }
  const token = mustToken(state);
  const client = new RelayClient({ relay: relayUrl(state), room_id, role, token });
  const result = await client.closeSide({
    summary: prepared.summary,
    closedraft_canonical: prepared.canonical,
  });
  // Consume the owner-answered wake signal: if the agent woke on owner_answered
  // and resolved by closing (rather than posting), the signal is spent — clear
  // it (merge-write) so the heartbeat does not re-wake on a consumed answer.
  if (state.owner_answered_wake) {
    clearOwnerAnsweredWake(state);
  }
  printJson({ ok: true, id: /** @type {any} */ (result.body)?.id, attempts: result.attempts });
}

async function cmdResume() {
  const room_id = required('room');
  const role = requiredRole();
  const state = resumeRoom(room_id, role);
  const fingerprint = await stateFingerprint(room_id, role);
  // Codex P2.2: tokens are sensitive. Default output redacts host_token /
  // guest_token and the state_file path (so the redacted output is safe to
  // relay to the owner). Use --debug for the unredacted form.
  const debug = Boolean(flags.debug);
  if (debug) {
    printJson({
      ok: true,
      state,
      fingerprint,
      state_file: `${STATE_DIR}/${room_id}-${role}.state.json`,
    });
    return;
  }
  const safe = { ...state };
  if (typeof safe.host_token === 'string') safe.host_token = '[redacted]';
  if (typeof safe.guest_token === 'string') safe.guest_token = '[redacted]';
  printJson({
    ok: true,
    state: safe,
    fingerprint,
    redacted: true,
    note: 'tokens redacted by default; use --debug for raw',
  });
}

async function cmdLint() {
  const room_id = required('room');
  const role = requiredRole();
  const state = mustReadState(room_id, role);
  if (flags['before-close']) {
    const draftPath = required('draft-file');
    const draft = JSON.parse(fs.readFileSync(draftPath, 'utf8'));
    const out = lintBeforeClose({ draft, state });
    printJson(out);
    if (out.findings.some((f) => f.severity === 'error')) process.exit(3);
    return;
  }
  if (flags.text !== undefined) {
    const out = lintBeforeSend({ text: String(flags.text), state });
    printJson(out);
    if (out.findings.some((f) => f.severity === 'error')) process.exit(3);
    return;
  }
  throw new Error('lint: specify --text TEXT or --before-close --draft-file PATH');
}

// Codex pass 3 P1: deterministic CLI affordances for the
// primary-agent-conversation owner approval flow (invariant 13). Without
// these, SKILL.md would have to tell users to hand-edit state JSON.
//
// Default v4 path is state-only (no relay round-trip). The async/cross-runtime
// fallback via relay /ask-owner + /owner-reply is OUT of Phase 1 scope; the
// lib has RelayClient.askOwner / RelayClient.postOwnerReply for that path
// when needed, but the CLI subcommands here only touch local state.

async function cmdAskOwner() {
  const room_id = required('room');
  const role = requiredRole();
  const question_id = required('question-id');
  const question_text = required('question-text');
  // Codex pass 4 P2: validate timeout_seconds is finite + positive before
  // writing state. Default 30 minutes.
  const timeoutRaw = flags['timeout-seconds'] ?? '1800';
  const timeout_seconds = Number(timeoutRaw);
  if (!Number.isFinite(timeout_seconds) || timeout_seconds <= 0) {
    throw new Error(`ask-owner: --timeout-seconds must be a positive number, got "${timeoutRaw}"`);
  }
  let context_snapshot = {};
  if (flags['context-json']) {
    try { context_snapshot = JSON.parse(String(flags['context-json'])); }
    catch { throw new Error('ask-owner: --context-json must be valid JSON'); }
  }
  const state = mustReadState(room_id, role);
  setPendingOwnerAsk(state, {
    question_id,
    question_text,
    asked_at: new Date().toISOString(),
    timeout_at: new Date(Date.now() + timeout_seconds * 1000).toISOString(),
    blocks_until: 'answered',
    context_snapshot,
  });
  printJson({
    ok: true,
    pending_owner_ask: { question_id, timeout_at: state.pending_owner_ask?.timeout_at },
    note: 'state-only: posts and agreement closes are now blocked until owner-reply or timeout',
  });
}

async function cmdOwnerReply() {
  const room_id = required('room');
  const role = requiredRole();
  const question_id = required('question-id');
  const decision = required('decision');
  if (decision !== 'approve' && decision !== 'reject') {
    throw new Error(`owner-reply: --decision must be approve or reject, got ${decision}`);
  }
  const evidence = required('evidence');
  // Codex pass 4 P2: validate source against the declared enum BEFORE
  // mutating state. APPROVAL_SOURCES is the v4 contract.
  const APPROVAL_SOURCES = ['primary_agent_conversation', 'owner_url', 'telegram_inbound'];
  const source = String(flags.source || 'primary_agent_conversation');
  if (!APPROVAL_SOURCES.includes(source)) {
    throw new Error(`owner-reply: --source must be one of ${APPROVAL_SOURCES.join('|')}, got "${source}"`);
  }
  const state = mustReadState(room_id, role);
  if (!state.pending_owner_ask || state.pending_owner_ask.question_id !== question_id) {
    throw new Error(`owner-reply: no pending_owner_ask matching question_id "${question_id}"`);
  }
  // Codex pass 4 P1: timed-out ask + decision=approve must FAIL CLOSED.
  // The previous warning-then-resolve path cleared pending_owner_ask, which
  // bypassed close.mjs's approval_after_timeout check (that check only fires
  // while pending is still set). Reject after timeout is allowed because it
  // cannot unblock an agreement; approve after timeout must be blocked.
  if (pendingAskTimedOut(state) && decision === 'approve') {
    process.stderr.write(
      `owner-reply: blocked — pending_owner_ask "${question_id}" timed out at ` +
      `${state.pending_owner_ask.timeout_at}. Approve after timeout is not allowed. ` +
      `Re-ask the owner (clawroom ask-owner with a new question_id) or record a reject instead.\n`
    );
    process.exit(6);
  }
  resolveOwnerAsk(state, {
    question_id,
    decision,
    source: /** @type {any} */ (source),
    ts: new Date().toISOString(),
    evidence,
  });
  printJson({
    ok: true,
    recorded: { question_id, decision, source },
    owner_approvals_count: state.owner_approvals.length,
    note: 'state-backed approval; close validator will now accept (or reject) based on this record',
  });
}

async function cmdReadiness() {
  const relay = relayUrl();
  /** @type {Record<string, unknown>} */
  const report = {
    version: VERSION,
    relay,
    state_dir: STATE_DIR,
    node: process.version,
  };
  // 1. State dir writable
  try {
    fs.mkdirSync(STATE_DIR, { recursive: true });
    const probe = path.join(STATE_DIR, `.readiness-${process.pid}`);
    fs.writeFileSync(probe, 'ok');
    fs.unlinkSync(probe);
    report.state_dir_writable = true;
  } catch (err) {
    report.state_dir_writable = false;
    report.state_dir_error = String(err?.message || err);
  }
  // 2. Relay reachable
  try {
    const res = await fetch(`${relay}/threads/__readiness__/join`, { method: 'GET' });
    report.relay_reachable = true;
    report.relay_status = res.status;
  } catch (err) {
    report.relay_reachable = false;
    report.relay_error = String(err?.message || err);
  }
  // 3. Admission key available (invariant 12)
  report.create_key_present = Boolean(process.env.CLAWROOM_CREATE_KEY);
  // 4. No legacy bridge processes
  try {
    const out = await execStr('pgrep -fl "bridge.mjs --thread" || true');
    report.legacy_bridge_processes = String(out).trim() ? out.trim().split('\n') : [];
  } catch {
    report.legacy_bridge_processes = [];
  }
  // 5. /events endpoint check.
  // The relay's threadExists check fires BEFORE action matching, so a
  // request against an unknown thread always returns "thread not found"
  // regardless of whether /events is deployed. To distinguish, we need
  // a known thread. If the caller passed --thread-id + --role, probe via
  // that state file's token; else skip with a tentative marker.
  const probeThread = flags['thread-id'];
  const probeRole = flags['role'];
  if (probeThread && probeRole) {
    try {
      const state = readState(probeThread, probeRole);
      const token = state ? (state.role === 'host' ? state.host_token : state.guest_token) : null;
      if (!token) throw new Error(`no state file for ${probeThread}-${probeRole}`);
      const res = await fetch(`${relay}/threads/${probeThread}/events?after=-1`, {
        headers: { authorization: `Bearer ${token}` },
      });
      const body = await res.text();
      let parsed;
      try { parsed = JSON.parse(body); } catch { parsed = {}; }
      report.events_endpoint_status = res.status;
      // /events deployed + valid auth = 200 array. Not deployed = 404 with error "not found" (action fallthrough).
      report.events_endpoint_present = res.status === 200 || (res.status === 404 && parsed?.error !== 'not found' && parsed?.error !== undefined);
      report.events_endpoint_probe_body_excerpt = body.slice(0, 200);
    } catch (err) {
      report.events_endpoint_present = false;
      report.events_endpoint_error = String(err?.message || err);
    }
  } else {
    // Cold-session path (no room yet): the relay's help JSON announces its
    // version + endpoint list, so /events presence is verifiable WITHOUT a
    // thread. The old behavior (tentative -> ok:false -> exit 4) made every
    // dutiful cold agent report a fake failure to its owner before doing
    // anything. Fall back to tentative only if the help JSON is unreadable
    // (e.g., a pre-0.5 relay that didn't expose version/endpoints).
    try {
      const res = await fetch(`${relay}/__help__`, { headers: { accept: 'application/json' } });
      const body = await res.text();
      let parsed;
      try { parsed = JSON.parse(body); } catch { parsed = {}; }
      const endpoints = Array.isArray(parsed?.endpoints) ? parsed.endpoints : [];
      const hasEvents = endpoints.some((e) => typeof e === 'string' && e.includes('/events'));
      if (hasEvents) {
        report.events_endpoint_present = true;
        report.events_endpoint_verified_via = 'relay_help_listing';
        if (typeof parsed?.version === 'string') report.relay_version = parsed.version;
      } else {
        report.events_endpoint_present = 'tentative_pass_relay_deploy_needed_to_verify';
        report.events_endpoint_note = 'relay help JSON did not list /events; pass --thread-id X --role Y for a real probe';
      }
    } catch (err) {
      report.events_endpoint_present = 'tentative_pass_relay_deploy_needed_to_verify';
      report.events_endpoint_note = `help probe failed (${String(err?.message || err).slice(0, 80)}); pass --thread-id X --role Y for a real probe`;
    }
  }
  // Codex P2.3: tentative pass is NOT ok by default. Machine gates upstream
  // could read ok=true and assume Phase 2-ready while /events isn't deployed.
  // Pass --allow-tentative to override for local pre-deploy checks.
  const allowTentative = Boolean(flags['allow-tentative']);
  const eventsVerified = report.events_endpoint_present === true;
  const eventsTentative = report.events_endpoint_present === 'tentative_pass_relay_deploy_needed_to_verify';
  const eventsOk = eventsVerified || (eventsTentative && allowTentative);
  const ok =
    report.state_dir_writable === true &&
    report.relay_reachable === true &&
    eventsOk &&
    Array.isArray(report.legacy_bridge_processes) && report.legacy_bridge_processes.length === 0;
  printJson({ ok, report, allow_tentative: allowTentative });
  if (!ok) process.exit(4);
}

async function cmdProbeLimits() {
  // Phase 1 task N6: discover relay's actual text/summary char limits by
  // creating a throwaway room and probing. Does not require a real
  // counterpart; aborts before mutual close.
  const relay = relayUrl();
  // Key is optional: open-alpha hosted relay accepts keyless creates; a
  // gated relay will answer 401 create_key_required and the error surfaces.
  const create_key = flags['create-key'] || process.env.CLAWROOM_CREATE_KEY;
  const probe = await createRoom({ topic: 'probe-limits', goal: 'discover relay text/summary char limits', relay, create_key });
  const room_id = probe.thread_id;
  const client = new RelayClient({ relay, room_id, role: 'host', token: probe.host_token });
  const sizes = [1_000, 2_000, 4_000, 8_000, 16_000, 32_000, 64_000, 128_000];
  /** @type {Record<string, unknown>} */
  const result = { room_id, message_limit_chars: null, message_limit_evidence: [] };
  for (const n of sizes) {
    const text = 'X'.repeat(n);
    try {
      await client.postMessage({ text, previous_cursor_or_parent_id: -1, logical_post_id: `probe-${n}` });
      /** @type {any[]} */ (result.message_limit_evidence).push({ n, ok: true });
    } catch (err) {
      /** @type {any[]} */ (result.message_limit_evidence).push({ n, ok: false, status: err?.status, message: String(err?.message || err).slice(0, 200) });
      if (err?.status === 413 || /too large|payload|413/i.test(String(err?.message || ''))) {
        result.message_limit_chars = n;
        break;
      }
      // Other errors are noise; record and continue.
    }
  }
  printJson(result);
}

// ---------- helpers ----------

function parseFlags(args) {
  /** @type {Record<string, string | boolean>} */
  const out = {};
  for (let i = 0; i < args.length; i++) {
    const a = args[i];
    if (a.startsWith('--')) {
      const key = a.slice(2);
      const next = args[i + 1];
      if (next === undefined || next.startsWith('--')) {
        out[key] = true;
      } else {
        out[key] = next;
        i++;
      }
    }
  }
  return out;
}

function required(name) {
  const v = flags[name];
  if (v === undefined || v === '' || v === true) {
    throw new Error(`missing required --${name}`);
  }
  return String(v);
}

function requiredRole() {
  const r = required('role');
  if (r !== 'host' && r !== 'guest') throw new Error(`--role must be host or guest, got ${r}`);
  return /** @type {'host' | 'guest'} */ (r);
}

function mustReadState(room_id, role) {
  const s = readState(room_id, role);
  if (!s) throw new Error(`no state for ${room_id}-${role}; run clawroom create or join first`);
  return s;
}

function mustToken(state) {
  const t = state.role === 'host' ? state.host_token : state.guest_token;
  if (!t) throw new Error(`state for ${state.room_id}-${state.role} has no token`);
  return t;
}

/**
 * Relay origin precedence: explicit --relay flag > the relay persisted in
 * this room's state (set at create/join from the invite origin) > env >
 * hosted default. State beats env so a BYO-relay room keeps talking to
 * its own relay even when the runtime exports CLAWROOM_RELAY for another.
 * @param {{ relay?: string } | null} [state]
 */
function relayUrl(state) {
  return flags.relay || state?.relay || process.env.CLAWROOM_RELAY || DEFAULT_RELAY_URL;
}

function printJson(obj) {
  process.stdout.write(JSON.stringify(obj, null, 2) + '\n');
}

function printHelp() {
  process.stdout.write(`clawroom v${VERSION} — v4 Direct Mode CLI

Subcommands:
